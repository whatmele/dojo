{
  "name": "dojo-cli",
  "version": "0.1.0",
  "description": "Agent Workspace CLI：管理多仓库工作区、开发会话生命周期与 AI Agent 上下文",
  "type": "module",
  "bin": {
    "dojo": "./dist/bin/dojo.js"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/src/templates && cp -r src/templates dist/src/templates",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "coding",
    "workspace",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
